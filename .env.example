# 🟢 SpacetimeDB Cloud (producción)
# En local usar ws://localhost:3000
# En producción usar la URL de spacetimedb.com tras publicar el módulo
NEXT_PUBLIC_SPACETIMEDB_URI=wss://maincloud.spacetimedb.com
NEXT_PUBLIC_SPACETIMEDB_DB_NAME=calculadora-once
SPACETIMEDB_URI=https://maincloud.spacetimedb.com
SPACETIMEDB_DB_NAME=calculadora-once

# 🛡️ Upstash Redis (producción)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 👤 NextAuth (producción)
NEXT_PUBLIC_URL=https://tu-dominio.vercel.app
NEXTAUTH_URL=https://tu-dominio.vercel.app
NEXTAUTH_SECRET=                     # openssl rand -base64 32

# 🔐 OAuth & Email
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
EMAIL_SERVER=
EMAIL_FROM=

# 🚀 Vercel Deployment (solo CI/CD)
VERCEL_TOKEN=                        # Settings > Tokens
VERCEL_ORG_ID=                       # Organization ID
VERCEL_PROJECT_ID=                   # Project ID
